unlock.MouseButton1Click:Connect(function()

	if string.lower(keyBox.Text) == "pinzking" then

		content.Visible = true

		keyBox.Visible = false
		unlock.Visible = false

		TweenService:Create(
			main,
			TweenInfo.new(0.25),
