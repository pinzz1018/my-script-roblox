--==================================================

mini.MouseButton1Click:Connect(function()

	minimized = not minimized

	if minimized then

		content.Visible = false
		credit.Visible = false

		TweenService:Create(
			main,
			TweenInfo.new(0.2),
			{Size = UDim2.new(0,390,0,45)}
		):Play()

		mini.Text = "+"

	else

		if not keyBox.Visible then
			content.Visible = true
		end

		credit.Visible = true

		TweenService:Create(
			main,
			TweenInfo.new(0.2),
			{Size = openedSize}
		):Play()

		mini.Text = "-"
	end
end)
